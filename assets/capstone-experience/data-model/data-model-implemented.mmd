erDiagram
    USER {
        string id
        string email
        string phone
    }

    SESSION {
        string id
        string userId
        string status
    }

    TAB {
        string id
        string sessionId
        double total
    }

    RECEIPT {
        string receiptId
        string sessionId
        double total
    }

    LOYALTY_ACCOUNT {
        string userId
        int points
        string tier
    }

    PROMOTION {
        string id
        string targetSegment
        string discount
    }

    MENU_ITEM {
        string id
        string name
        double price
    }

    USER ||--o{ SESSION : starts
    SESSION ||--|| TAB : owns
    SESSION ||--o| RECEIPT : closes_as
    USER ||--o{ RECEIPT : views
    USER ||--|| LOYALTY_ACCOUNT : has
    USER }o--o{ PROMOTION : qualifies_for
    MENU_ITEM }o--o{ TAB : appears_in
